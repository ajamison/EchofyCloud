@model Echofy.Web.Models.Admin.EditUserViewModel
@{
    ViewData["Title"] = "Edit User";
    ViewData["ActivePage"] = "AdminUsers";
    Layout = "_Layout";
}

<div class="pb-5">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-8 col-xl-6">
            <div class="mb-4">
                <h2 class="mb-0">Edit User</h2>
                <p class="text-body-tertiary mb-0">@Model.Email</p>
            </div>
            <div class="card">
                <div class="card-body">
                    <form asp-action="EditUser" method="post">
                        <input type="hidden" asp-for="Id" />
                        <div class="mb-3">
                            <label class="form-label" asp-for="FullName">Full Name</label>
                            <input class="form-control" asp-for="FullName" />
                            <span class="text-danger" asp-validation-for="FullName"></span>
                        </div>
                        <div class="mb-3">
                            <label class="form-label" asp-for="SelectedRole">Role</label>
                            <select class="form-select" asp-for="SelectedRole" asp-items="Model.RoleOptions"></select>
                        </div>
                        <div class="mb-4">
                            <label class="form-label" asp-for="ClientId">Client</label>
                            <select class="form-select" asp-for="ClientId" asp-items="Model.ClientOptions">
                                <option value="">— No Client —</option>
                            </select>
                        </div>
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">Save Changes</button>
                            <a asp-action="Users" class="btn btn-phoenix-secondary">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
