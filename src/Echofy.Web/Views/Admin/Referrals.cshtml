@using Echofy.Application.DTOs
@model IReadOnlyList<AdminReferralDto>
@{
    ViewData["Title"] = "Referrals";
    ViewData["ActivePage"] = "AdminReferrals";
    Layout = "_Layout";

    var pending  = Model.Where(r => r.Status == "Pending").ToList();
    var approved = Model.Where(r => r.Status == "Approved").ToList();
    var issued   = Model.Where(r => r.Status == "Issued").ToList();
    var cancelled = Model.Where(r => r.Status == "Cancelled").ToList();
}

<div class="row g-3 mb-4 align-items-center">
    <div class="col-auto"><h2 class="mb-0">Referral Program</h2></div>
</div>

@* Summary stats *@
<div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl-3">
        <div class="card h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="bg-primary-subtle rounded-3 p-3">
                    <span class="fas fa-users text-primary fs-4"></span>
                </div>
                <div>
                    <div class="text-body-tertiary fs-9">Total Referrals</div>
                    <div class="fw-bold fs-4">@Model.Count</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="bg-warning-subtle rounded-3 p-3">
                    <span class="fas fa-clock text-warning fs-4"></span>
                </div>
                <div>
                    <div class="text-body-tertiary fs-9">Pending Review</div>
                    <div class="fw-bold fs-4">@pending.Count</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="bg-success-subtle rounded-3 p-3">
                    <span class="fas fa-dollar-sign text-success fs-4"></span>
                </div>
                <div>
                    <div class="text-body-tertiary fs-9">Total Issued</div>
                    <div class="fw-bold fs-4">@issued.Sum(r => r.PointsEarned) pts</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="bg-info-subtle rounded-3 p-3">
                    <span class="fas fa-check-circle text-info fs-4"></span>
                </div>
                <div>
                    <div class="text-body-tertiary fs-9">Approved (Pending Issue)</div>
                    <div class="fw-bold fs-4">@approved.Sum(r => r.PointsEarned) pts</div>
                </div>
            </div>
        </div>
    </div>
</div>

@* Main table *@
<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">All Referral Rewards</h5>
        @if (pending.Count > 0)
        {
            <span class="badge bg-warning text-dark">@pending.Count pending approval</span>
        }
    </div>
    @if (Model.Count == 0)
    {
        <div class="card-body text-center py-5">
            <span class="fas fa-gift fa-3x text-body-tertiary mb-3 d-block"></span>
            <h5 class="text-body-tertiary">No referrals yet</h5>
            <p class="text-body-secondary fs-9">Referral rewards will appear here once customers start sharing their codes.</p>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Referrer</th>
                        <th>Code</th>
                        <th>New Member</th>
                        <th>Welcome Coupon</th>
                        <th>Joined</th>
                        <th>Reward</th>
                        <th>Gift Card</th>
                        <th>Status</th>
                        <th>Approved</th>
                        <th>Issued</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in Model)
                    {
                        var badgeClass = r.Status switch
                        {
                            "Issued"    => "bg-success",
                            "Approved"  => "bg-info",
                            "Cancelled" => "bg-danger",
                            _           => "bg-warning text-dark"
                        };
                        <tr>
                            <td>
                                <div class="fw-semibold">@(string.IsNullOrEmpty(r.ReferrerName) ? r.ReferrerEmail : r.ReferrerName)</div>
                                <div class="text-body-tertiary fs-10">@r.ReferrerEmail</div>
                            </td>
                            <td><code>@r.ReferralCode</code></td>
                            <td class="text-body-secondary">@r.UsedByEmail</td>
                            <td>
                                @if (r.WelcomeCoupon is not null)
                                {
                                    <code class="text-success">@r.WelcomeCoupon</code>
                                }
                                else { <span class="text-body-tertiary">—</span> }
                            </td>
                            <td class="text-body-secondary text-nowrap">@r.UsedAt.ToLocalTime().ToString("MMM d, yyyy")</td>
                            <td class="fw-bold text-success">@r.PointsEarned pts</td>
                            <td><span class="text-body-tertiary">—</span></td>
                            <td><span class="badge @badgeClass">@r.Status</span></td>
                            <td class="text-body-secondary text-nowrap">@(r.ApprovedAt.HasValue ? r.ApprovedAt.Value.ToLocalTime().ToString("MMM d") : "—")</td>
                            <td class="text-body-secondary text-nowrap">@(r.IssuedAt.HasValue ? r.IssuedAt.Value.ToLocalTime().ToString("MMM d") : "—")</td>
                            <td class="text-end text-nowrap">
                                @if (r.Status == "Pending")
                                {
                                    <form asp-action="ApproveReferralReward" asp-route-id="@r.RewardId" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-success me-1" title="Approve">
                                            <span class="fas fa-check"></span>
                                        </button>
                                    </form>
                                    <form asp-action="CancelReferralReward" asp-route-id="@r.RewardId" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-danger" title="Cancel"
                                                onclick="return confirm('Cancel this reward?')">
                                            <span class="fas fa-xmark"></span>
                                        </button>
                                    </form>
                                }
                                else if (r.Status == "Approved")
                                {
                                    <form asp-action="IssueReferralReward" asp-route-id="@r.RewardId" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-primary me-1" title="Mark as Issued">
                                            <span class="fas fa-paper-plane"></span> Issue
                                        </button>
                                    </form>
                                    <form asp-action="CancelReferralReward" asp-route-id="@r.RewardId" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-danger" title="Cancel"
                                                onclick="return confirm('Cancel this reward?')">
                                            <span class="fas fa-xmark"></span>
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <span class="text-body-tertiary fs-10">—</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
