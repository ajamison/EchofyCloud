@model Echofy.Web.Models.Admin.CreateUserViewModel
@{
    ViewData["Title"] = "Add User";
    ViewData["ActivePage"] = "AdminUsers";
    Layout = "_Layout";
}

<div class="pb-5">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-8 col-xl-6">
            <div class="mb-4">
                <h2 class="mb-0">Add User</h2>
                <p class="text-body-tertiary mb-0">Create a new user account</p>
            </div>
            <div class="card">
                <div class="card-body">
                    <form asp-action="CreateUser" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 fs-9 mb-3" role="alert"></div>

                        <div class="mb-3">
                            <label class="form-label" asp-for="FullName">Full Name</label>
                            <input class="form-control" asp-for="FullName" autofocus />
                            <span class="text-danger fs-9" asp-validation-for="FullName"></span>
                        </div>
                        <div class="mb-3">
                            <label class="form-label" asp-for="Email">Email</label>
                            <input class="form-control" asp-for="Email" type="email" />
                            <span class="text-danger fs-9" asp-validation-for="Email"></span>
                        </div>
                        <div class="mb-3">
                            <label class="form-label" asp-for="Password">Password</label>
                            <input class="form-control" asp-for="Password" type="password" />
                            <span class="text-danger fs-9" asp-validation-for="Password"></span>
                        </div>
                        <div class="mb-3">
                            <label class="form-label" asp-for="ConfirmPassword">Confirm Password</label>
                            <input class="form-control" asp-for="ConfirmPassword" type="password" />
                            <span class="text-danger fs-9" asp-validation-for="ConfirmPassword"></span>
                        </div>
                        <div class="mb-3">
                            <label class="form-label" asp-for="SelectedRole">Role</label>
                            <select class="form-select" asp-for="SelectedRole" asp-items="Model.RoleOptions">
                                <option value="">— No Role —</option>
                            </select>
                        </div>
                        <div class="mb-4">
                            <label class="form-label" asp-for="ClientId">Client</label>
                            <select class="form-select" asp-for="ClientId" asp-items="Model.ClientOptions">
                                <option value="">— No Client —</option>
                            </select>
                        </div>
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">Create User</button>
                            <a asp-action="Users" class="btn btn-phoenix-secondary">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
