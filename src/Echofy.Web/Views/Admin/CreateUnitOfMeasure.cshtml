@model Echofy.Web.Models.Admin.UnitOfMeasureViewModel
@{
    ViewData["Title"] = "Add Unit of Measure";
    ViewData["ActivePage"] = "AdminUnitsOfMeasure";
    Layout = "_Layout";
}

<div class="pb-5">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-7 col-xl-5">
            <div class="mb-4">
                <h2 class="mb-0">Add Unit of Measure</h2>
                <p class="text-body-tertiary mb-0">Create a new unit of measure</p>
            </div>
            <div class="card">
                <div class="card-body">
                    <form asp-action="CreateUnitOfMeasure" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 fs-9 mb-3" role="alert"></div>

                        <div class="mb-3">
                            <label class="form-label" asp-for="Name">Name <span class="text-danger">*</span></label>
                            <input class="form-control" asp-for="Name" autofocus placeholder="e.g. Ounce" />
                            <span class="text-danger fs-9" asp-validation-for="Name"></span>
                        </div>
                        <div class="mb-4">
                            <label class="form-label" asp-for="Abbreviation">Abbreviation <span class="text-danger">*</span></label>
                            <input class="form-control" asp-for="Abbreviation" placeholder="e.g. oz" />
                            <div class="form-text">Short symbol used on product pages (e.g. oz, lb, ml, kg).</div>
                            <span class="text-danger fs-9" asp-validation-for="Abbreviation"></span>
                        </div>
                        <div class="mb-4">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" asp-for="IsActive" role="switch" />
                                <label class="form-check-label" asp-for="IsActive">Active</label>
                            </div>
                        </div>
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">Create Unit</button>
                            <a asp-action="UnitsOfMeasure" class="btn btn-phoenix-secondary">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
