@model List<Echofy.Application.DTOs.CompanyListItemDto>
@{
    ViewData["Title"] = "Companies";
    ViewData["ActivePage"] = "AdminCompanies";
    Layout = "_Layout";
}

<div class="row g-3 mb-4 align-items-center">
    <div class="col"><h2 class="mb-0">Companies</h2></div>
    <div class="col-auto">
        <a asp-action="Create" class="btn btn-primary btn-sm">
            <span class="fas fa-plus me-2"></span>Add Company
        </a>
    </div>
</div>

@if (TempData["Success"] is string msg)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @msg
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-sm table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Name</th>
                        <th>Client</th>
                        <th>Email</th>
                        <th>Phone</th>
                        <th>City</th>
                        <th class="text-center">Products</th>
                        <th class="text-center">Invoices</th>
                        <th class="text-center">Active</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in Model)
                    {
                        <tr>
                            <td class="fw-semibold">@c.Name</td>
                            <td class="text-body-tertiary">@(c.ClientName ?? "—")</td>
                            <td>@(c.Email ?? "—")</td>
                            <td>@(c.Phone ?? "—")</td>
                            <td>@(c.City ?? "—")</td>
                            <td class="text-center">@c.ProductCount</td>
                            <td class="text-center">@c.InvoiceCount</td>
                            <td class="text-center">
                                @if (c.IsActive)
                                {
                                    <span class="badge badge-phoenix badge-phoenix-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge badge-phoenix badge-phoenix-secondary">Inactive</span>
                                }
                            </td>
                            <td class="text-end">
                                <a asp-action="Edit" asp-route-id="@c.Id" class="btn btn-sm btn-phoenix-secondary">Edit</a>
                                <form asp-action="Delete" asp-route-id="@c.Id" method="post" class="d-inline"
                                      onsubmit="return confirm('Delete @c.Name?')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-phoenix-danger">Delete</button>
                                </form>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="9" class="text-center text-body-tertiary py-4">No companies yet.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
