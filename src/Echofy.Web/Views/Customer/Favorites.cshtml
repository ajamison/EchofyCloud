@model IReadOnlyList<Echofy.Application.DTOs.ProductDto>
@{
    ViewData["Title"] = "My Favorites";
    ViewData["ActivePage"] = "CustomerFavorites";
    Layout = "_Layout";
}

<div class="row g-3 mb-4 align-items-center">
    <div class="col-auto"><h2 class="mb-0">My Favorites</h2></div>
    <div class="col-auto ms-auto text-body-tertiary fs-9">@Model.Count product(s)</div>
</div>

@if (Model.Count == 0)
{
    <div class="text-center py-5">
        <span class="fas fa-heart fa-3x text-body-tertiary mb-3 d-block"></span>
        <h5 class="text-body-tertiary">No favorites yet</h5>
        <p class="text-body-tertiary fs-9 mb-0">Browse products and click the heart icon to save your favorites.</p>
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var p in Model)
        {
            <div class="col-sm-6 col-lg-4 col-xl-3">
                <div class="card h-100">
                    @if (!string.IsNullOrEmpty(p.ImageUrl))
                    {
                        <img src="@p.ImageUrl" class="card-img-top object-fit-cover" style="height:180px;" alt="@p.Name">
                    }
                    <div class="card-body d-flex flex-column">
                        <div class="mb-1">
                            @foreach (var cat in p.CategoryNames)
                            {
                                <span class="badge badge-phoenix badge-phoenix-primary fs-10 me-1">@cat</span>
                            }
                        </div>
                        <h6 class="card-title mb-1 flex-grow-1">@p.Name</h6>
                        <div class="d-flex align-items-center justify-content-between mt-2">
                            <span class="fw-bold text-primary">$@p.Price.ToString("N2")</span>
                            <a href="/p/@p.ShortId" class="btn btn-phoenix-primary btn-sm">View</a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
