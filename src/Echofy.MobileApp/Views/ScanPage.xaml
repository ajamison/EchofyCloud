<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:zxing="clr-namespace:ZXing.Net.Maui.Controls;assembly=ZXing.Net.MAUI.Controls"
             xmlns:vm="clr-namespace:Echofy.MobileApp.ViewModels"
             x:Class="Echofy.MobileApp.Views.ScanPage"
             x:DataType="vm:ScanViewModel"
             Title="Scan Barcode">

    <Grid>
        <!-- Full-screen barcode reader view -->
        <zxing:CameraBarcodeReaderView x:Name="BarcodeReaderView"
                                       HorizontalOptions="Fill"
                                       VerticalOptions="Fill"
                                       BarcodesDetected="BarcodeReaderView_BarcodesDetected" />

        <!-- Scan frame overlay -->
        <Border HorizontalOptions="Center"
                VerticalOptions="Center"
                WidthRequest="260"
                HeightRequest="160"
                Stroke="White"
                StrokeThickness="2"
                BackgroundColor="Transparent" />

        <!-- Status bar at bottom -->
        <VerticalStackLayout VerticalOptions="End"
                             Padding="16,12"
                             BackgroundColor="#CC000000">
            <Label Text="{Binding StatusMessage}"
                   TextColor="White"
                   HorizontalOptions="Center"
                   FontSize="14" />
            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               Color="White"
                               HorizontalOptions="Center" />
        </VerticalStackLayout>
    </Grid>

</ContentPage>
